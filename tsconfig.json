{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"moduleResolution": "Node16",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"outDir": "./dist"
	},
	"include": [
		"tests/**/*",
		"pages/**/*",
		"services/**/*",
		"fixtures/**/*",
		"utils/**/*",
		"config/**/*",
		"data/**/*"
	]
}
